{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/user_prompt_submit_policy.py",
            "statusMessage": "Snapshot do turno + política de prompt",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/pre_tool_use_policy.py",
            "statusMessage": "Guardrail de Bash",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/post_tool_use_review.py",
            "statusMessage": "Revisão pós-Bash",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/stop_hcd_err_audit.py",
            "statusMessage": "Auditoria HCD-ERR no fim do turno",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
