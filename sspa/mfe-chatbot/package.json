{
  "name": "@mfe/mfe-chatbot",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "rotate-build-number": "node ./scripts/rotate-build-number.cjs",
    "dev": "vite --port 4200",
    "build": "npm run rotate-build-number && tsc && vite build",
    "build:standalone": "vite build --config vite.standalone.config.ts",
    "preview": "vite preview --port 4200"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "single-spa-react": "^6.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-single-spa": "^1.1.0"
  }
}
