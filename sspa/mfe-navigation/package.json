{
  "name": "@mfe/navigation",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "rotate-build-number": "node ./scripts/rotate-build-number.cjs",
    "copy-build-number": "cp build-number.json ./output/build-number.json",
    "dev": "vite --config vite.standalone.config.ts",
    "dev:mife": "vite",
    "build": "npm run rotate-build-number && npm run build:mife && npm run build:standalone && npm run copy-build-number",
    "build:mife": "vite build",
    "build:standalone": "vite build --config vite.standalone.config.ts"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-single-spa": "^1.1.0"
  }
}
