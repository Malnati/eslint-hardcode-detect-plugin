{
  "name": "eslint-plugin-hardcode-detect",
  "version": "0.2.8",
  "description": "ESLint plugin: hardcoded value detection and error-message standardization (implementation in progress).",
  "homepage": "https://github.com/malnati/eslint-hardcode-detect-plugin/tree/main/packages/eslint-plugin-hardcode-detect#readme",
  "bugs": {
    "url": "https://github.com/malnati/eslint-hardcode-detect-plugin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/malnati/eslint-hardcode-detect-plugin.git",
    "directory": "packages/eslint-plugin-hardcode-detect"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "npm run build && node --test tests/index.test.mjs tests/no-hardcoded-strings-r1.test.mjs tests/no-hardcoded-strings-call-sites.test.mjs tests/no-hardcoded-strings-r2.test.mjs tests/no-hardcoded-strings-secrets.test.mjs tests/r3-data-file-writers.test.mjs e2e/r2-multi-file.e2e.mjs e2e/r3-data-files.e2e.mjs e2e/nest-workspace.e2e.mjs",
    "release:pack": "npm pack",
    "release:publish": "npm publish --access public"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "hardcode",
    "i18n"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "eslint-plugin-eslint-plugin": "^7.0.0",
    "eslint-plugin-n": "^17.15.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  }
}
