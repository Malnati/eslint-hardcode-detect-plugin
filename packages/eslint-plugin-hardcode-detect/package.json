{
  "name": "eslint-plugin-hardcode-detect",
  "version": "0.0.0",
  "description": "ESLint plugin: detecção de hardcodes e padronização de mensagens de erro (implementação em andamento).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "test": "npm run build && node --test tests/index.test.mjs tests/no-hardcoded-strings-r1.test.mjs e2e/hello-world.e2e.mjs e2e/nest-workspace.e2e.mjs"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "hardcode",
    "i18n"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.18.0",
    "eslint-plugin-eslint-plugin": "^7.0.0",
    "eslint-plugin-n": "^17.15.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0"
  }
}
